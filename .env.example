# Copy this file to .env and fill in your keys (do NOT commit .env).

# Primary provider — used for the brain (chat) AND speech-to-text (Whisper).
# Get it at: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_key_here

# Fallback provider for the brain only (used if the OpenAI call fails).
# Get it at: https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_key_here
